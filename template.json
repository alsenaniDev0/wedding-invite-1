{
    "id": "royal-wedding",
    "name": "دعوة زفاف ملكية",
    "version": "1.0.0",
    "schemaVersion": "1.0.0",
    "type": "custom",
    "language": "ar",
    "direction": "rtl",
    "html": "index.html",
    "css": "style.css",
    "fields": [
        {
            "key": "showIcon",
            "label": "إظهار الأيقونة",
            "type": "select",
            "formTab": "design",
            "group": "visibility",
            "required": true,
            "defaultValue": "yes",
            "options": [
                {
                    "label": "نعم",
                    "value": "yes"
                },
                {
                    "label": "لا",
                    "value": "no"
                }
            ],
            "width": "half"
        },
        {
            "type": "icon",
            "label": "الأيقونة",
            "key": "icon",
            "options": [
                {
                    "value": "💍",
                    "label": "💍"
                },
                {
                    "value": "🤍",
                    "label": "🤍"
                },
                {
                    "value": "✨",
                    "label": "✨"
                },
                {
                    "value": "🌿",
                    "label": "🌿"
                }
            ],
            "defaultValue": "💍",
            "required": true,
            "visibleWhen": {
                "field": "showIcon",
                "equals": "yes"
            },
            "requiredWhen": {
                "field": "showIcon",
                "equals": "yes"
            },
            "formTab": "design"
        },
        {
            "key": "showTitle",
            "label": "إظهار عنوان الدعوة",
            "type": "select",
            "formTab": "data",
            "group": "visibility",
            "required": true,
            "defaultValue": "yes",
            "options": [
                {
                    "label": "نعم",
                    "value": "yes"
                },
                {
                    "label": "لا",
                    "value": "no"
                }
            ],
            "width": "half"
        },
        {
            "defaultValue": "دعوة زواج",
            "required": true,
            "key": "title",
            "maxLength": 60,
            "label": "عنوان الدعوة",
            "type": "text",
            "visibleWhen": {
                "field": "showTitle",
                "equals": "yes"
            },
            "requiredWhen": {
                "field": "showTitle",
                "equals": "yes"
            }
        },
        {
            "minLength": 10,
            "key": "message",
            "label": "نص الدعوة",
            "maxLength": 220,
            "type": "textarea",
            "defaultValue": "بكل الحب والسرور نتشرف بدعوتكم لمشاركتنا فرحة زواجنا",
            "required": true
        },
        {
            "key": "names",
            "label": "أسماء العروسين",
            "type": "names",
            "placeholder": "مثال: محمد",
            "minItems": 2,
            "required": true,
            "separator": " و ",
            "maxItems": 2,
            "designControls": {
                "font": {
                    "enabled": true,
                    "label": "خط أسماء العروسين",
                    "selector": ".hero-names"
                }
            }
        },
        {
            "type": "date",
            "required": true,
            "label": "تاريخ الحفل",
            "key": "date"
        },
        {
            "type": "time",
            "key": "time",
            "label": "وقت الحفل",
            "defaultValue": "20:00"
        },
        {
            "hint": "اضغط لاختيار الموقع من Google Map",
            "required": true,
            "key": "location",
            "label": "الموقع",
            "type": "map",
            "placeholder": "اختر الموقع من الخريطة"
        },
        {
            "defaultValue": "حضوركم يتمم فرحتنا ويزيد ليلتنا جمالاً",
            "required": true,
            "minLength": 5,
            "type": "textarea",
            "label": "رسالة الختام",
            "key": "closing",
            "maxLength": 180
        },
        {
            "hint": "ضع رابط YouTube وسيعمل كصوت للخلفية بعد فتح الدعوة",
            "patternMessage": "الرابط يجب أن يبدأ بـ http أو https",
            "pattern": "^https?:\\/\\/.+",
            "label": "رابط YouTube للصوت",
            "key": "soundUrl",
            "placeholder": "https://youtu.be/...",
            "type": "youtube"
        }
    ],
    "features": {
        "feelings": {
            "enabled": true,
            "approvalMode": "manual",
            "preventDuplicate": true,
            "rateLimitMinutes": 5,
            "title": "شارك مشاعرك",
            "description": "اكتب رسالة جميلة لأصحاب الدعوة"
        },
        "rsvp": {
            "enabled": true,
            "preventDuplicate": true,
            "title": "هل ستحضر؟",
            "description": "يسعدنا معرفة حضورك للمناسبة"
        }
    }
}